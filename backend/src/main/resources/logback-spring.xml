<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <conversionRule
            conversionWord="safeMsg"
            converterClass="com.example.taxassistant.common.logging.SensitiveDataMaskingConverter"/>
    <conversionRule
            conversionWord="safeEx"
            converterClass="com.example.taxassistant.common.logging.SensitiveThrowableProxyConverter"/>

    <property
            name="CONSOLE_LOG_PATTERN"
            value="%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %safeMsg%n%safeEx"/>

    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
